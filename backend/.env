# Tavily：用于 Tavily 联网搜索
TAVILY_API_KEY=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

# 文件夹导入：允许的根路径白名单（逗号分隔），不配置则禁用「从文件夹导入」
# IMPORT_FOLDER_ALLOWED_BASE_PATHS=/data/kb_import,/var/docs

# Markdown 本地绝对路径图片：允许读取的根路径白名单（逗号分隔）。例如 Typora 图片目录，上传的 .md 中若引用该目录下的图片则会解析
MARKDOWN_LOCAL_IMAGE_ALLOWED_BASE_PATHS="/Users/xiangqingping.1/Library/Application Support/typora-user-images"

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 模型配置 (可根据需要调整)
# 注意：如果未设置，将使用 backend/app/core/llm/__init__.py 中的默认配置
DEFAULT_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# DEFAULT_CHAT_MODEL=Pro/deepseek-ai/DeepSeek-R1
# DEFAULT_VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct
DEFAULT_RERANKER_MODEL=Qwen/Qwen3-Reranker-8B

# 检索配置
MAX_RETRIEVAL_RESULTS=20
MAX_CONTEXT_LENGTH=4000
RERANK_TOP_K=10

# 知识库配置
MAX_KB_PORTRAIT_SIZE=20
PORTRAIT_UPDATE_THRESHOLD=50

# 视频模态配置
FFMPEG_PATH=/opt/homebrew/bin/ffmpeg

# ========== 飞书机器人（长连接，与 Web 同进程）==========
# 接入说明见 docs/飞书接入实现方案-详细设计.md；控制台请使用「长连接」订阅 im.message.receive_v1，勿与 Webhook URL 混用。
# 填好凭证后将 FEISHU_WS_ENABLED 改为 true 并重启后端。
FEISHU_WS_ENABLED=true
# FEISHU_APP_ID=cli_a9347f3ad1f8dbd9
# FEISHU_APP_SECRET=axw8kBPGz9pIrXGY9Casye3XlHSyhTV6
FEISHU_APP_ID=cli_a935dbcfbc615bef
FEISHU_APP_SECRET=gVDQ10fXr0AJdmYIF4EESb5nXWzNc2d0


# 与开放平台「事件订阅」中的 Encrypt Key / Verification Token 一致；未开启加密时可留空
FEISHU_ENCRYPT_KEY=
FEISHU_VERIFICATION_TOKEN=

# 可选：固定知识库 ID（逗号分隔）；留空则与 Web 端一致走智能路由
# FEISHU_DEFAULT_KB_IDS=

# 可选：群聊除 @ 机器人外，可用前缀触发，例如 /rag（留空则仅 @ 机器人）
# FEISHU_GROUP_TRIGGER_PREFIX=

# 可选：手动指定机器人 open_id；不填则启动时请求 bot/v3/info 自动缓存
# FEISHU_BOT_OPEN_ID=

# 去重 TTL（秒）、会话后端 memory|redis、是否忽略机器人自身消息
FEISHU_DEDUP_TTL_SEC=600
FEISHU_SESSION_BACKEND=memory
FEISHU_IGNORE_BOT_MESSAGES=true

# 回答中的配图：最多条数、是否从 MinIO 读图并上传飞书
FEISHU_MAX_REPLY_IMAGES=6
FEISHU_IMAGE_SEND_ENABLED=true

# 可选：前端站点根 URL，用于文末「完整排版」链接
# FEISHU_WEB_BASE_URL=https://你的前端域名

# 是否在话题内回复（群线程）
FEISHU_REPLY_IN_THREAD=false

# 是否先发一条「正在处理」提示
FEISHU_TYPING_HINT=true
FEISHU_TYPING_HINT_TEXT="😚正在检索个人知识库...\n✨稍等片刻(👉ﾟヮﾟ)👉"

# WebSocket / TLS：同时作用于 open_timeout 与 ssl_handshake_timeout（代码默认已 300s）
FEISHU_WS_OPEN_TIMEOUT=300
# WSL 等环境飞书 WSS 走 IPv6 易卡住，默认 true：解析域名后强制 IPv4 + SNI
FEISHU_WS_PREFER_IPV4=true