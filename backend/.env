MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# FastAPI 配置
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# JWT 配置
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 文件上传配置
MAX_FILE_SIZE=100MB
ALLOWED_EXTENSIONS=pdf,docx,doc,txt,md,jpg,jpeg,png,gif

# 知识库导入：多渠道搜索/下载（可选，仅「按关键词搜索图片导入」需要）
# SerpAPI：用于 Google 图片搜索，见 https://serpapi.com/
