# DEFAULT_CHAT_MODEL=Pro/deepseek-ai/DeepSeek-R1
# DEFAULT_VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct
DEFAULT_RERANKER_MODEL=Qwen/Qwen3-Reranker-8B

# 检索配置
