# 文件夹导入：允许的根路径白名单（逗号分隔），不配置则禁用「从文件夹导入」
# IMPORT_FOLDER_ALLOWED_BASE_PATHS=/data/kb_import,/var/docs

# Markdown 本地绝对路径图片：允许读取的根路径白名单（逗号分隔）。例如 Typora 图片目录，上传的 .md 中若引用该目录下的图片则会解析
MARKDOWN_LOCAL_IMAGE_ALLOWED_BASE_PATHS="/Users/xiangqingping.1/Library/Application Support/typora-user-images"

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 模型配置 (可根据需要调整)
# 注意：如果未设置，将使用 backend/app/core/llm/__init__.py 中的默认配置
