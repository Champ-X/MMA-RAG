# 环境变量配置文件
# 请复制此文件为 .env 并填入真实的API密钥

# SiliconFlow API 配置
SILICONFLOW_API_KEY=sk-myzbsafvwjkqhvagmaoauwkrgumuzsjlukjbarymfprwbrzj

# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-9fdea2b1eaa04a81b67855f628e606ce

# 数据库配置
DATABASE_URL=sqlite:///./app.db
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# MinIO 配置（本地 MinIO 默认账号为 minioadmin/minioadmin；若用 Docker 或自设账号请与此一致）
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# FastAPI 配置
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# JWT 配置
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 文件上传配置
MAX_FILE_SIZE=100MB
ALLOWED_EXTENSIONS=pdf,docx,doc,txt,md,jpg,jpeg,png,gif

# 知识库导入：多渠道搜索/下载（可选，仅「按关键词搜索图片导入」需要）
# SerpAPI：用于 Google 图片搜索，见 https://serpapi.com/
SERPAPI_KEY="7688d782266ac23f3654fdc7e34aaac39c443c86facc9125897af8b360f3eb29"
# Pixabay：用于 Pixabay 图片搜索，见 https://pixabay.com/api/docs/
PIXABAY_API_KEY="52137187-63ac86ae794d4d92ad663891c"

# 文件夹导入：允许的根路径白名单（逗号分隔），不配置则禁用「从文件夹导入」
# IMPORT_FOLDER_ALLOWED_BASE_PATHS=/data/kb_import,/var/docs

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 模型配置 (可根据需要调整)
# 注意：如果未设置，将使用 backend/app/core/llm/__init__.py 中的默认配置
DEFAULT_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
# DEFAULT_CHAT_MODEL=Pro/deepseek-ai/DeepSeek-R1
# DEFAULT_VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct
DEFAULT_RERANKER_MODEL=Qwen/Qwen3-Reranker-8B

# 检索配置
MAX_RETRIEVAL_RESULTS=20
MAX_CONTEXT_LENGTH=4000
RERANK_TOP_K=10

# 知识库配置
MAX_KB_PORTRAIT_SIZE=20
PORTRAIT_UPDATE_THRESHOLD=50