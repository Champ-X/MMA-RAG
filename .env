# 环境变量配置文件
# 请复制此文件为 .env 并填入真实的API密钥

# SiliconFlow API 配置
SILICONFLOW_API_KEY=sk-myzbsafvwjkqhvagmaoauwkrgumuzsjlukjbarymfprwbrzj

# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-9fdea2b1eaa04a81b67855f628e606ce

# 数据库配置
DATABASE_URL=sqlite:///./app.db
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# MinIO 配置
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin123456
MINIO_SECURE=false

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# FastAPI 配置
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# JWT 配置
SECRET_KEY=your-super-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 文件上传配置
MAX_FILE_SIZE=100MB
ALLOWED_EXTENSIONS=pdf,docx,doc,txt,md,jpg,jpeg,png,gif

# 日志配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Celery 配置
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# 模型配置 (可根据需要调整)
DEFAULT_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-8B
DEFAULT_CHAT_MODEL=Qwen/Qwen3-235B-A22B-Thinking-2507
DEFAULT_VISION_MODEL=Qwen/Qwen3-VL-32B-Instruct
DEFAULT_RERANKER_MODEL=Qwen/Qwen3-Reranker-8B

# 检索配置
MAX_RETRIEVAL_RESULTS=20
MAX_CONTEXT_LENGTH=4000
RERANK_TOP_K=10

# 知识库配置
MAX_KB_PORTRAIT_SIZE=20
PORTRAIT_UPDATE_THRESHOLD=50